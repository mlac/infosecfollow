# Copy to .env and fill in. .env is gitignored — never commit real secrets.

# Claude Code subscription token. Generate on a logged-in machine with:
#   claude setup-token
# Valid ~1 year; rotate before it expires.
CLAUDE_CODE_OAUTH_TOKEN=

# GitHub fine-grained personal access token with Contents: Read and write on the
# mlac/infosecfollow repository. Used to fetch and push the generated site.
GITHUB_TOKEN=

# Push over HTTPS so the token credential helper applies (the run script points
# origin here). Leave as-is unless the repo moves.
GIT_REMOTE_URL=https://github.com/mlac/infosecfollow.git

# Commit identity for the automated "briefing ..." commits.
GIT_AUTHOR_NAME=infosecfollow-bot
GIT_AUTHOR_EMAIL=infosecfollow@users.noreply.github.com
